{
  "name": "promptaichemy",
  "displayName": "PromptAIChemy",
  "publisher": "CodeWithAkhil",
  "description": "Enhance your prompts using a local AI model before sending to Claude Code, Cursor, or any AI coding assistant",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akkitheakhil/promptaichemy.git"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptEnhancer",
          "title": "Prompt Enhancer",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "promptEnhancer": [
        {
          "type": "webview",
          "id": "promptEnhancer.sidebar",
          "name": "Prompt Enhancer"
        }
      ]
    },
    "configuration": {
      "title": "Prompt Enhancer",
      "properties": {
        "promptEnhancer.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for the Ollama API"
        },
        "promptEnhancer.model": {
          "type": "string",
          "default": "llama3.1",
          "description": "Ollama model to use for prompt enhancement"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package",
    "prepackage": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
